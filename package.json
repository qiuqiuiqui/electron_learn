{
  "name": "electron-vue-snake",
  "version": "1.0.0",
  "description": "Electron + Vue 3 иҙӘеҗғиӣҮжёёжҲҸ",
  "author": "qiuqiuiqui",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite --electron",
    "electron:build": "vite build && electron-builder",
    "electron:start": "electron ."
  },
  "dependencies": {
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.electron.snake",
    "productName": "иҙӘеҗғиӣҮжёёжҲҸ",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": ["zip"],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": ["zip"],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "qiuqiuiqui",
      "repo": "electron_learn"
    }
  }
}
